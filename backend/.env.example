# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=10kbooks
DB_SYNCHRONIZE=true
DB_LOGGING=true

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# 文件存储
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
PDF_MAX_SIZE=52428800

# 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@10kbooks.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=万卷书苑 <noreply@10kbooks.com>

# Stripe配置
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# PayPal配置
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
PAYPAL_MODE=sandbox

# OpenAI配置
OPENAI_API_KEY=sk-xxxxx
OPENAI_MODEL=gpt-4

# Elasticsearch配置
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=10kbooks

# AWS S3配置（可选）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=10kbooks-uploads

# 第三方OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# 支付抽成比例
PLATFORM_COMMISSION_RATE=0.15

# 多语言默认配置
DEFAULT_LANGUAGE=zh-CN
SUPPORTED_LANGUAGES=en-US,zh-CN,zh-TW,ja-JP,ko-KR
