# ============================================
# 万卷书苑 / 10kBooks - Docker 环境变量示例
# ============================================

# ==========================================
# 通用配置
# ==========================================
NODE_ENV=production

# ==========================================
# API 服务端口
# ==========================================
API_PORT=3000
WEB_PORT=80
WEB_SSL_PORT=443

# ==========================================
# PostgreSQL 配置
# ==========================================
POSTGRES_DB=10kbooks
POSTGRES_USER=10kbooks
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_PORT=5432

# ==========================================
# Redis 配置
# ==========================================
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379

# ==========================================
# Elasticsearch 配置
# ==========================================
ELASTIC_PASSWORD=your_elastic_password_here
ES_PORT=9200
KIBANA_PORT=5601

# ==========================================
# JWT 配置
# ==========================================
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ==========================================
# MinIO / S3 / OSS 配置
# ==========================================
# MinIO (开发/本地)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password

# AWS S3 (生产环境推荐)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-east-1
S3_BUCKET=10kbooks-production

# 阿里云 OSS (可选)
OSS_ENDPOINT=oss-cn-hongkong.aliyuncs.com
OSS_BUCKET=10kbooks-oss
OSS_ACCESS_KEY_ID=your_aliyun_access_key
OSS_ACCESS_KEY_SECRET=your_aliyun_secret_key

# ==========================================
# 监控配置
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password
GRAFANA_ROOT_URL=https://monitor.10kbooks.com
LOKI_PORT=3100

# ==========================================
# 监控配置
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_secure_grafana_password
GRAFANA_ROOT_URL=https://monitor.10kbooks.com
LOKI_PORT=3100
