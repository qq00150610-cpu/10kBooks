# 项目配置
PROJECT_NAME=万卷书苑
PROJECT_ID=com.10kbooks.app
PROJECT_CODE=10kBooks
APP_VERSION=1.0.0

# API配置
API_BASE_URL=https://api.10kbooks.com
API_TIMEOUT=30000

# 存储配置
HIVE_BOX_USER=userBox
HIVE_BOX_BOOK=bookBox
HIVE_BOX_PROGRESS=progressBox
HIVE_BOX_DOWNLOAD=downloadBox
HIVE_BOX_SETTINGS=settingsBox

# 阅读器配置
READER_FONT_SIZE_MIN=12
READER_FONT_SIZE_MAX=32
READER_LINE_HEIGHT_MIN=1.2
READER_LINE_HEIGHT_MAX=2.0

# 缓存配置
IMAGE_CACHE_MAX_AGE=604800
BOOK_CACHE_MAX_SIZE=524288000

# 分页配置
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_LARGE=50

# 广告配置
AD_PLACEMENT_HOME=home_banner
AD_PLACEMENT_BOOK_DETAIL=book_detail_interstitial
AD_PLACEMENT_READER=reader_rewarded
